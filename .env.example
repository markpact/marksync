# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  marksync .env — Configuration                                             ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── Sync Server ───────────────────────────────────────────────────────────────
MARKSYNC_HOST=0.0.0.0
MARKSYNC_PORT=8765
MARKSYNC_SERVER=ws://localhost:8765
MARKSYNC_SERVER_DOCKER=ws://sync-server:8765

# ── DSL API ───────────────────────────────────────────────────────────────────
MARKSYNC_API_HOST=0.0.0.0
MARKSYNC_API_PORT=8080

# ── Ollama (lokalne modele) ───────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_URL_DOCKER=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# ── LiteLLM / OpenRouter (zdalne modele) ─────────────────────────────────────
# Model do generowania pipeline'ów i kodu:
LITELLM_MODEL=openrouter/google/gemini-3-flash-preview

# Model z vision (opcjonalny, do analizy obrazów/diagramów):
VISION_MODEL=openrouter/google/gemini-3-flash-preview

# Klucz API OpenRouter (wymagany dla zdalnych modeli):
# openrouter/google/gemini-3-flash-preview
OPENROUTER_API_KEY=sk-or-v1-TWOJ_KLUCZ

# Opcjonalnie: nadpisz base URL dla LiteLLM:
# LITELLM_API_BASE=https://openrouter.ai/api/v1

# Parametry generowania:
LITELLM_TEMPERATURE=0.3
LITELLM_MAX_TOKENS=8192

# ── Project ───────────────────────────────────────────────────────────────────
PROJECT_README=README.md
LOG_LEVEL=INFO
GENERATE_OUTPUT_DIR=./generated
